{
  "extends":         "@tsconfig/node22/tsconfig.json",
  "include":         [
    "vite.config.*",
    "vitest.config.*",
    "vitest.setup.*",
    "playwright.config.*",
    "eslint.config.*",
    "prettier.config.*",
    "stylelint.config.*"
  ],
  "compilerOptions": {
    "noEmit":           true,
    "tsBuildInfoFile":  "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "types":            [
      "node"
    ]
  }
}

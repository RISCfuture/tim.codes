{
  "name": "tim.codes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:eslint": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss,sass}\" --fix",
    "lint:knip": "knip",
    "lint": "run-s lint:oxlint 'lint:eslint' 'lint:stylelint' 'lint:knip'",
    "format": "prettier --write src/",
    "doc": "npx typedoc --out docs src",
    "ci:unit": "vitest --run",
    "ci:build": "run-p type-check \"build-only {@}\" --"
  },
  "dependencies": {
    "@sentry/vue": "^10.53.1",
    "@vueuse/core": "^14.3.0",
    "cldr-data": "^36.0.5",
    "cldrjs": "^0.5.5",
    "lodash-es": "^4.18.1",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/cldrjs": "^0.4.29",
    "@types/jsdom": "^28.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/setimmediate": "^1.0.4",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/compiler-dom": "^3.5.34",
    "@vue/server-renderer": "^3.5.34",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "npm-run-all2": "^9.0.0",
    "oxlint": "^1.66.0",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "setimmediate": "^1.0.5",
    "stylelint": "^17.12.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "terser": "^5.47.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vite-plugin-csp-guard": "^4.0.1",
